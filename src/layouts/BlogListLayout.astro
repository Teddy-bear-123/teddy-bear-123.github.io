---
import Layout from '../layouts/Layout.astro'
import groupBy from 'lodash/groupBy'
import keys from 'lodash/keys'
import { slugifySpace } from '@utils/format'
import { useLocale } from '@utils/locale'
import { formatDateMD } from '@utils/format'
import { getCollection } from 'astro:content'

const { path, t, locale } = useLocale(Astro.url)
let { tag, category } = Astro.props

const allPosts = await getCollection('posts', ({ data }) => !data.draft)

const filteredPosts = allPosts
    .filter((post) => {
        if (tag) return post.data.tags?.includes(tag)
        if (category) return post.data.categories?.includes(category)
        return true
    })
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())

const tags = new Set(
    filteredPosts.flatMap((p) => p.data.tags ?? [])
)

const postsByYear = groupBy(filteredPosts, (p) => p.data.pubDate.getFullYear())
const result = keys(postsByYear)
    .map((year) => ({
        year,
        list: postsByYear[year].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    }))
    .filter((i) => !isNaN(Number(i.year)))
    .sort((a, b) => Number(b.year) - Number(a.year))
---

<Layout title={t('nav.posts')}>
    <main class="mt-8">
        {result.map((yearItem) => (
            <>
                <div class="text-2xl font-bold italic my-3">{yearItem.year}</div>
                <ul class="px-2">
                    {yearItem.list.map((post) => (
                        <li class="my-1 flex transition-all duration-300">
                            <span style={{ flex: '0 0 5rem' }}>
                                <time class="mr-2">{formatDateMD(post.data.pubDate.toISOString())}</time>
                            </span>
                            <a rel="prefetch-intent" href={path(`/posts/${post.slug}/`)} class="panda-link-static">
                                {post.data.title}
                            </a>
                        </li>
                    ))}
                </ul>
            </>
        ))}

        <div class="mt-6">
            {[...tags].map((tag) => (
                <a
                    class="mr-1 text-sm panda-link my-1 hover:font-bold"
                    href={'/tags/' + slugifySpace(tag) + '/'}
                >
                    #{tag}
                </a>
            ))}
        </div>
    </main>
</Layout>
