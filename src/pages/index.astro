---
import Layout from '../layouts/Layout.astro'
import { getCollection, getEntry, render } from 'astro:content'
import { formatDateMD } from '@utils/format'

export const prerender = true

const introEntry = await getEntry('about', 'intro')
const IntroContent = introEntry ? (await render(introEntry)).Content : null

const projectEntries = await getCollection('projects')
const allItems = await Promise.all(
    projectEntries
        .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
        .map(async (p) => {
            const rendered = await render(p)
            return { ...p.data, id: p.id, Content: rendered.Content }
        })
)

const researchItems = allItems.filter(p => p.tags?.includes('research'))
const regularProjects = allItems.filter(p => !p.tags?.includes('research'))

const allPosts = await getCollection('posts', ({ data }) => !data.draft)
const latestPosts = allPosts
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 1)

const allLangs = [...new Set(regularProjects.flatMap(p => p.languages ?? []))]
---

<Layout title="C. V. Rishi">
    <div class="home-wrapper">
        <canvas id="bg-canvas"></canvas>

        <section class="hero-new">
            <div class="hero-content-new">
                <h1 class="hero-title-new">Systems Programmer | CV Research</h1>
                <div class="hero-desc-new prose dark:prose-invert">
                    {IntroContent ? <IntroContent /> : <p>Welcome to my personal site.</p>}
                </div>
                <p class="hero-cta-new">
                    Interested in computer vision or systems architecture? Let's talk.
                </p>
                <div class="contact-links-new">
                    <span>github: <a href="https://github.com/teddy-bear-123" target="_blank">@teddy-bear-123</a></span>
                    <span>email: <a href="mailto:cvrishi.devl@gmail.com">cvrishi [at] devl [dot] gmail</a></span>
                </div>
            </div>
        </section>

        {latestPosts.map(post => (
            <section class="latest-blog">
                <div class="blog-preview-card">
                    <div class="blog-header">
                        <span class="blog-label">LATEST FROM THE BLOG</span>
                    </div>
                    <div class="blog-body">
                        <h2><a href={`/posts/${post.id}/`}>{post.data.title}</a> · <span class="date">{formatDateMD(post.data.pubDate.toISOString())}</span></h2>
                        <p>{post.data.description || "Read the latest post on my blog."}</p>
                        <a href={`/posts/${post.id}/`} class="read-more">Read post →</a>
                    </div>
                </div>
            </section>
        ))}

        <section class="section" id="projects-section">
            <div class="section-header">
                <div class="main-toggles">
                    <button class="toggle-btn active" data-main="projects">Projects</button>
                    <button class="toggle-btn" data-main="research">Research</button>
                </div>
                
                <div class="filter-chips" id="lang-filters">
                    <button class="chip active" data-filter="all">all</button>
                    {allLangs.map(s => (
                        <button class="chip" data-filter={s}>{s}</button>
                    ))}
                </div>
            </div>

            <div class="content-container">
                <!-- Projects Grid -->
                <div class="project-grid-wide active" id="project-grid">
                    {regularProjects.map((p) => (
                        <article class="project-card-wide" data-langs={(p.languages ?? []).join(',')}>
                            <div class="card-header">
                                <h3>{p.name}</h3>
                                <span class="status-pill">open source</span>
                            </div>
                            {p.thumbnail && (
                                <div class="card-img">
                                    <img src={p.thumbnail} alt={p.name} />
                                </div>
                            )}
                            <div class="card-content">
                                <div class="card-desc">
                                    <p.Content />
                                </div>
                                <div class="card-footer">
                                    <div class="card-tags">
                                        {(p.languages ?? []).map(s => <span class="tech-tag">{s}</span>)}
                                        {(p.tags ?? []).map(t => <span class="tag-pill">{t}</span>)}
                                    </div>
                                    {p.github && <a href={p.github} class="card-link" target="_blank">GitHub</a>}
                                </div>
                            </div>
                        </article>
                    ))}
                </div>

                <!-- Research List -->
                <div class="research-list-container" id="research-list" style="display: none;">
                    <div class="research-list">
                        {researchItems.map(pub => (
                            <div class="research-item-new">
                                <div class="pub-header">
                                    <span class="pub-venue">{pub.venue}</span>
                                    <span class="tag-pill research-badge">Research</span>
                                </div>
                                <h3>
                                    {pub.link ? (
                                        <a href={pub.link} target="_blank" class="research-link">{pub.name} ↗</a>
                                    ) : (
                                        pub.name
                                    )}
                                </h3>
                                <p class="pub-authors">{pub.authors}</p>
                                <div class="pub-desc">
                                    <pub.Content />
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layout>

<script>
    function initBg() {
        const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement
        if (!canvas) return
        const ctx = canvas.getContext('2d')
        if (!ctx) return

        let width = canvas.width = window.innerWidth
        let height = canvas.height = window.innerHeight

        window.addEventListener('resize', () => {
            width = canvas.width = window.innerWidth
            height = canvas.height = window.innerHeight
        })

        const points: {x: number, y: number, vx: number, vy: number}[] = []
        for (let i = 0; i < 50; i++) {
            points.push({
                x: Math.random() * width,
                y: Math.random() * height,
                vx: (Math.random() - 0.5) * 0.5,
                vy: (Math.random() - 0.5) * 0.5
            })
        }

        function draw() {
            ctx.clearRect(0, 0, width, height)
            ctx.strokeStyle = document.documentElement.classList.contains('dark') 
                ? 'rgba(235, 153, 161, 0.1)' 
                : 'rgba(29, 116, 132, 0.05)'
            ctx.lineWidth = 1

            points.forEach((p, i) => {
                p.x += p.vx
                p.y += p.vy

                if (p.x < 0 || p.x > width) p.vx *= -1
                if (p.y < 0 || p.y > height) p.vy *= -1

                for (let j = i + 1; j < points.length; j++) {
                    const p2 = points[j]
                    const dist = Math.hypot(p.x - p2.x, p.y - p2.y)
                    if (dist < 200) {
                        ctx.beginPath()
                        ctx.moveTo(p.x, p.y)
                        ctx.lineTo(p2.x, p2.y)
                        ctx.stroke()
                    }
                }
            })

            requestAnimationFrame(draw)
        }

        draw()
    }

    function setupInteractions() {
        const toggleBtns = document.querySelectorAll('.toggle-btn')
        const chips = document.querySelectorAll('.chip')
        const projectGrid = document.getElementById('project-grid')
        const researchList = document.getElementById('research-list')
        const langFilters = document.getElementById('lang-filters')
        const cards = document.querySelectorAll('.project-card-wide')

        toggleBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                toggleBtns.forEach(b => b.classList.remove('active'))
                btn.classList.add('active')
                
                const target = (btn as HTMLElement).dataset.main
                if (target === 'projects') {
                    projectGrid!.style.display = 'grid'
                    researchList!.style.display = 'none'
                    langFilters!.style.display = 'flex'
                } else {
                    projectGrid!.style.display = 'none'
                    researchList!.style.display = 'block'
                    langFilters!.style.display = 'none'
                }
            })
        })

        chips.forEach(chip => {
            chip.addEventListener('click', () => {
                chips.forEach(c => c.classList.remove('active'))
                chip.classList.add('active')
                const filter = (chip as HTMLElement).dataset.filter
                cards.forEach(card => {
                    const langs = ((card as HTMLElement).dataset.langs || '').split(',')
                    if (filter === 'all' || langs.includes(filter)) {
                        (card as HTMLElement).style.display = ''
                    } else {
                        (card as HTMLElement).style.display = 'none'
                    }
                })
            })
        })
    }

    initBg()
    setupInteractions()
    document.addEventListener('astro:page-load', () => {
        initBg()
        setupInteractions()
    })
</script>

<style>
    #bg-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        pointer-events: none;
    }

    .hero-new {
        padding: 4rem 0 3rem;
        text-align: center;
    }

    .hero-content-new {
        max-width: 800px;
        margin: 0 auto;
    }

    .hero-title-new {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: rgb(var(--color-text-heading));
        font-family: monospace;
    }

    .hero-desc-new {
        font-size: 1.05rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
        color: rgb(var(--color-text-body));
        text-align: left;
    }

    .hero-cta-new {
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    .contact-links-new {
        display: flex;
        justify-content: center;
        gap: 2rem;
        font-family: monospace;
        font-size: 0.9rem;
    }

    .contact-links-new a {
        color: rgb(var(--color-primary-main));
        text-decoration: none;
        border-bottom: 1px solid transparent;
    }

    .contact-links-new a:hover {
        border-bottom-color: rgb(var(--color-primary-main));
    }

    .latest-blog {
        margin: 2rem 0 4rem;
    }

    .blog-preview-card {
        border: 1px solid rgb(var(--color-primary-main) / 0.2);
        background: rgb(var(--color-primary-main) / 0.02);
        border-radius: 4px;
        overflow: hidden;
    }

    .blog-header {
        padding: 0.75rem 1.5rem;
        border-bottom: 1px solid rgb(var(--color-primary-main) / 0.1);
        background: rgb(var(--color-primary-main) / 0.05);
    }

    .blog-label {
        font-family: monospace;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        font-weight: 700;
        color: rgb(var(--color-primary-main));
    }

    .blog-body {
        padding: 1.5rem;
    }

    .blog-body h2 {
        font-size: 1.4rem;
        margin: 0 0 1rem;
    }

    .blog-body h2 a {
        color: rgb(var(--color-text-heading));
        text-decoration: none;
    }

    .blog-body .date {
        font-size: 0.9rem;
        color: rgb(var(--color-text-body));
        opacity: 0.6;
    }

    .blog-body p {
        color: rgb(var(--color-text-body));
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }

    .read-more {
        display: inline-block;
        font-family: monospace;
        color: rgb(var(--color-primary-main));
        text-decoration: none;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .main-toggles {
        display: flex;
        gap: 1rem;
    }

    .toggle-btn {
        background: transparent;
        border: none;
        font-family: monospace;
        font-size: 1.2rem;
        font-weight: 700;
        color: rgb(var(--color-text-body));
        opacity: 0.4;
        cursor: pointer;
        transition: all 0.2s;
        padding: 0;
    }

    .toggle-btn.active {
        opacity: 1;
        color: rgb(var(--color-primary-main));
    }

    .filter-chips {
        display: flex;
        gap: 0.5rem;
    }

    .chip {
        font-family: monospace;
        font-size: 0.8rem;
        background: transparent;
        border: 1px solid rgb(var(--color-primary-main) / 0.3);
        color: rgb(var(--color-text-body));
        padding: 0.2rem 0.6rem;
        cursor: pointer;
    }

    .chip.active {
        background: rgb(var(--color-primary-main));
        color: white;
        border-color: rgb(var(--color-primary-main));
    }

    .project-grid-wide {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
        gap: 2rem;
    }

    @media (max-width: 600px) {
        .project-grid-wide {
            grid-template-columns: 1fr;
        }
    }

    .project-card-wide {
        border: 1px solid rgb(var(--color-primary-main) / 0.2);
        background: rgb(var(--color-primary-main) / 0.01);
        display: flex;
        flex-direction: column;
        transition: border-color 0.3s;
    }

    .project-card-wide:hover {
        border-color: rgb(var(--color-primary-main) / 0.5);
    }

    .card-header {
        padding: 0.75rem 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgb(var(--color-primary-main) / 0.1);
    }

    .card-header h3 {
        font-size: 1rem;
        margin: 0;
        font-family: monospace;
    }

    .status-pill {
        font-size: 0.7rem;
        font-family: monospace;
        color: #00d2d3;
        border: 1px solid #00d2d3;
        padding: 0.1rem 0.4rem;
        border-radius: 2px;
    }

    .card-img {
        width: 100%;
        height: 200px;
        overflow: hidden;
        border-bottom: 1px solid rgb(var(--color-primary-main) / 0.1);
    }

    .card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .card-content {
        padding: 1rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .card-desc {
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
        color: rgb(var(--color-text-body));
        flex: 1;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .tech-tag, .tag-pill {
        font-size: 0.75rem;
        font-family: monospace;
        padding: 0.1rem 0.4rem;
        border: 1px solid rgb(var(--color-primary-main) / 0.3);
        color: rgb(var(--color-text-body));
    }

    .research-list {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }

    .research-item-new {
        border-left: 3px solid rgb(var(--color-primary-main));
        padding-left: 1.5rem;
    }

    .pub-header {
        margin-bottom: 0.5rem;
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .pub-venue {
        font-size: 0.75rem;
        font-family: monospace;
        color: rgb(var(--color-primary-main));
        font-weight: 700;
        text-transform: uppercase;
    }

    .research-badge {
        background: #ff4757;
        color: white;
        border-color: #ff4757;
        font-weight: 800;
        font-size: 0.65rem;
    }

    .research-item-new h3 {
        font-size: 1.3rem;
        margin: 0.5rem 0;
    }

    .research-link {
        color: rgb(var(--color-text-heading));
        text-decoration: none;
        border-bottom: 1px solid rgb(var(--color-primary-main) / 0.3);
    }

    .research-link:hover {
        border-bottom-color: rgb(var(--color-primary-main));
    }

    .pub-authors {
        font-size: 0.9rem;
        color: rgb(var(--color-text-body));
        opacity: 0.7;
        margin-bottom: 1rem;
    }

    .pub-desc {
        font-size: 0.95rem;
        line-height: 1.6;
        color: rgb(var(--color-text-body));
    }

    .card-link {
        font-family: monospace;
        font-size: 0.85rem;
        padding: 0.3rem 0.6rem;
        border: 1px solid rgb(var(--color-primary-main));
        color: rgb(var(--color-primary-main));
        text-decoration: none;
    }

    .card-link:hover {
        background: rgb(var(--color-primary-main));
        color: white;
    }
</style>
