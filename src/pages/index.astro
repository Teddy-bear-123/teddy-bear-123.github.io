---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

export const prerender = true

const projectEntries = await getCollection('projects')
const projects = await Promise.all(
    projectEntries
        .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
        .map(async (p) => {
            const { Content } = await p.render()
            return { ...p.data, slug: p.slug, Content }
        })
)

const publications = [
    {
        title: 'Procedural Video Understanding for Recipe Variations',
        venue: 'ICVGIP 2025',
        authors: 'C V Rishi, Shubham Goel, Farzana S, Aditya Arun, C V Jawahar',
        desc: 'Temporal reasoning framework for understanding how procedures vary across different interpretations. Featured in The Hindu.',
        link: 'https://arxiv.org/abs/2601.06198'
    }
]

const allStacks = [...new Set(projects.flatMap(p => p.stack ?? []))]
---

<Layout title="C. V. Rishi">
    <div class="home-wrapper">
        <!-- Animated Background -->
        <div class="bg-animation"></div>

        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <h1 class="hero-title">C. V. Rishi</h1>
                <p class="hero-subtitle">B.Tech CSE @ Mahindra University</p>
                
                <div class="hero-bio">
                    <p>Research intern at CVIT, IIIT Hyderabad under Prof. C V Jawahar, working on procedural video understanding. My work was accepted at ICVGIP 2025 and featured in <em>The Hindu</em>.</p>
                    <p>I write systems software in C and Rust. Interested in computer vision, low-level programming, and making tools that do one thing exceptionally well.</p>
                </div>

                <div class="hero-cta">
                    <a href="/posts/" class="cta-btn primary">Blog</a>
                    <a href="#projects" class="cta-btn secondary">Projects</a>
                    <a href="/about/" class="cta-btn secondary">About</a>
                </div>
            </div>
        </section>

        <!-- Projects Section -->
        <section class="section" id="projects">
            <div class="section-header">
                <h2>Projects</h2>
                <div class="filter-chips">
                    <button class="chip active" data-filter="all">all</button>
                    {allStacks.map(s => (
                        <button class="chip" data-filter={s}>{s}</button>
                    ))}
                </div>
            </div>

            <div class="project-grid" id="project-grid">
                {projects.map((p) => (
                    <article class="project-card" data-stack={(p.stack ?? []).join(',')}>
                        <h3 class="card-title">{p.title}</h3>
                        
                        <div class="card-meta">
                            {(p.stack ?? []).map(s => <span class="tech-tag">{s}</span>)}
                        </div>

                        <div class="card-desc">
                            <p.Content />
                        </div>

                        <div class="card-links">
                            {p.github && (
                                <a href={p.github} class="card-link" target="_blank">source ↗</a>
                            )}
                            {p.site && (
                                <a href={p.site} class="card-link" target="_blank">live ↗</a>
                            )}
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <!-- Research Section -->
        <section class="section">
            <h2>Research</h2>
            <div class="research-list">
                {publications.map(pub => (
                    <div class="research-item">
                        <div class="pub-meta">
                            <span class="pub-venue">{pub.venue}</span>
                        </div>
                        <h3>
                            <a href={pub.link} target="_blank" class="research-link">{pub.title} ↗</a>
                        </h3>
                        <p class="pub-authors">{pub.authors}</p>
                        <p class="pub-desc">{pub.desc}</p>
                    </div>
                ))}
            </div>
        </section>

        <!-- Contact Section -->
        <section class="section contact-section">
            <h2>Get in Touch</h2>
            <div class="contact-list">
                <a href="mailto:cvrishi.devl@gmail.com" class="contact-link">
                    <span class="label">email</span>
                    <span class="value">cvrishi.devl@gmail.com</span>
                </a>
                <a href="https://github.com/teddy-bear-123" target="_blank" class="contact-link">
                    <span class="label">github</span>
                    <span class="value">teddy-bear-123</span>
                </a>
                <a href="mailto:se23ucse044@mahindrauniversity.edu.in" class="contact-link">
                    <span class="label">college</span>
                    <span class="value">se23ucse044@mahindrauniversity.edu.in</span>
                </a>
            </div>
        </section>
    </div>
</Layout>

<script>
    function setupFilters() {
        const chips = document.querySelectorAll('.chip')
        const cards = document.querySelectorAll('.project-card')

        chips.forEach(chip => {
            chip.addEventListener('click', () => {
                chips.forEach(c => c.classList.remove('active'))
                chip.classList.add('active')

                const filter = chip.dataset.filter
                cards.forEach(card => {
                    const stacks = (card.dataset.stack || '').split(',')
                    if (filter === 'all' || stacks.includes(filter)) {
                        card.style.display = ''
                    } else {
                        card.style.display = 'none'
                    }
                })
            })
        })
    }

    setupFilters()
    document.addEventListener('astro:page-load', setupFilters)
</script>

<style>
    .home-wrapper {
        position: relative;
        overflow: hidden;
    }

    .bg-animation {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: 
            repeating-linear-gradient(
                90deg,
                transparent,
                transparent 2px,
                rgba(29, 116, 132, 0.02) 2px,
                rgba(29, 116, 132, 0.02) 4px
            ),
            repeating-linear-gradient(
                0deg,
                transparent,
                transparent 40px,
                rgba(29, 116, 132, 0.05) 40px,
                rgba(29, 116, 132, 0.05) 80px
            );
        animation: drift 20s linear infinite;
        pointer-events: none;
        z-index: 0;
    }

    @keyframes drift {
        0% { transform: translateY(0); }
        100% { transform: translateY(80px); }
    }

    .dark .bg-animation {
        background: 
            repeating-linear-gradient(
                90deg,
                transparent,
                transparent 2px,
                rgba(235, 153, 161, 0.03) 2px,
                rgba(235, 153, 161, 0.03) 4px
            ),
            repeating-linear-gradient(
                0deg,
                transparent,
                transparent 40px,
                rgba(235, 153, 161, 0.06) 40px,
                rgba(235, 153, 161, 0.06) 80px
            );
    }

    .hero {
        position: relative;
        z-index: 1;
        padding: 4rem 0;
        margin-bottom: 3rem;
        text-align: center;
    }

    .hero-content {
        max-width: 52ch;
        margin: 0 auto;
    }

    .hero-title {
        font-size: clamp(2.5rem, 8vw, 3.5rem);
        font-weight: 800;
        margin: 0 0 0.5rem;
        color: rgb(var(--color-text-heading));
        letter-spacing: -0.02em;
    }

    .hero-subtitle {
        font-size: 0.95rem;
        color: rgb(var(--color-primary-main));
        opacity: 0.8;
        margin: 0 0 2rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .hero-bio {
        font-size: 0.95rem;
        line-height: 1.75;
        color: rgb(var(--color-text-body));
        margin-bottom: 2.5rem;
        text-align: left;
    }

    .hero-bio p {
        margin-bottom: 1rem;
    }

    .hero-cta {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .cta-btn {
        padding: 0.75rem 1.75rem;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
        border: 2px solid rgb(var(--color-primary-main));
    }

    .cta-btn.primary {
        background: rgb(var(--color-primary-main));
        color: white;
    }

    .cta-btn.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(29, 116, 132, 0.2);
    }

    .cta-btn.secondary {
        background: transparent;
        color: rgb(var(--color-primary-main));
    }

    .cta-btn.secondary:hover {
        background: rgb(var(--color-primary-main) / 0.08);
    }

    .section {
        position: relative;
        z-index: 1;
        margin-bottom: 4rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
    }

    .section-header h2 {
        font-size: 1.8rem;
        margin: 0;
        color: rgb(var(--color-text-heading));
    }

    .filter-chips {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
    }

    .chip {
        padding: 0.4rem 0.9rem;
        border: 1.5px solid rgb(var(--color-primary-main) / 0.3);
        border-radius: 20px;
        background: transparent;
        color: rgb(var(--color-text-body));
        font-size: 0.8rem;
        font-family: monospace;
        cursor: pointer;
        transition: all 0.2s;
    }

    .chip:hover,
    .chip.active {
        border-color: rgb(var(--color-primary-main));
        background: rgb(var(--color-primary-main) / 0.1);
        color: rgb(var(--color-primary-main));
    }

    .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 32rem), 1fr));
        gap: 1.75rem;
    }

    .project-card {
        border: 1px solid rgb(var(--color-primary-main) / 0.15);
        border-radius: 8px;
        padding: 1.75rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: all 0.3s;
        background: rgb(var(--color-primary-main) / 0.02);
    }

    .project-card:hover {
        border-color: rgb(var(--color-primary-main) / 0.4);
        box-shadow: 0 8px 24px rgba(29, 116, 132, 0.08);
        transform: translateY(-2px);
    }

    .card-title {
        font-size: 1.3rem;
        font-weight: 700;
        margin: 0;
        color: rgb(var(--color-text-heading));
    }

    .card-meta {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .tech-tag {
        background: rgb(var(--color-primary-main) / 0.12);
        color: rgb(var(--color-primary-main));
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-family: monospace;
        font-weight: 600;
    }

    .card-desc {
        flex: 1;
        font-size: 0.9rem;
        line-height: 1.7;
        color: rgb(var(--color-text-body));
    }

    .card-desc :global(p) {
        margin: 0 0 0.8rem;
    }

    .card-desc :global(ul) {
        margin: 0.5rem 0;
        padding-left: 1.5rem;
    }

    .card-desc :global(li) {
        margin-bottom: 0.3rem;
    }

    .card-links {
        display: flex;
        gap: 1.25rem;
        padding-top: 0.5rem;
    }

    .card-link {
        font-size: 0.85rem;
        font-family: monospace;
        color: rgb(var(--color-primary-main));
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s;
    }

    .card-link:hover {
        border-bottom-color: rgb(var(--color-primary-main));
    }

    .research-list {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .research-item {
        border-left: 3px solid rgb(var(--color-primary-main));
        padding-left: 1.5rem;
    }

    .pub-meta {
        margin-bottom: 0.5rem;
    }

    .pub-venue {
        font-size: 0.7rem;
        font-family: monospace;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgb(var(--color-primary-main));
        opacity: 0.7;
    }

    .research-item h3 {
        font-size: 1.2rem;
        margin: 0.3rem 0;
        color: rgb(var(--color-text-heading));
    }

    .research-link {
        color: rgb(var(--color-primary-main));
        text-decoration: none;
        border-bottom: 1px solid rgb(var(--color-primary-main) / 0.3);
        transition: all 0.2s;
    }

    .research-link:hover {
        border-bottom-color: rgb(var(--color-primary-main));
    }

    .pub-authors {
        font-size: 0.8rem;
        color: rgb(var(--color-text-body));
        opacity: 0.6;
        margin: 0.3rem 0;
    }

    .pub-desc {
        font-size: 0.9rem;
        line-height: 1.65;
        color: rgb(var(--color-text-body));
        margin: 0;
    }

    .contact-section {
        margin-top: 5rem;
        padding-top: 3rem;
        border-top: 2px solid rgb(var(--color-primary-main) / 0.1);
    }

    .contact-list {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        max-width: 40ch;
    }

    .contact-link {
        display: flex;
        gap: 2rem;
        align-items: baseline;
        text-decoration: none;
        padding: 0.75rem 0;
        border-bottom: 1px solid rgb(var(--color-primary-main) / 0.08);
        transition: border-color 0.2s;
    }

    .contact-link:hover {
        border-bottom-color: rgb(var(--color-primary-main) / 0.3);
    }

    .contact-link .label {
        font-family: monospace;
        font-size: 0.75rem;
        color: rgb(var(--color-primary-main));
        opacity: 0.7;
        flex: 0 0 5rem;
        text-transform: lowercase;
        font-weight: 600;
    }

    .contact-link .value {
        font-size: 0.95rem;
        color: rgb(var(--color-text-body));
        transition: color 0.2s;
    }

    .contact-link:hover .value {
        color: rgb(var(--color-primary-main));
    }

    @media (max-width: 768px) {
        .hero {
            padding: 2.5rem 0;
            margin-bottom: 2rem;
        }

        .hero-title {
            font-size: 2rem;
        }

        .section-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .project-grid {
            grid-template-columns: 1fr;
        }

        .contact-link {
            flex-direction: column;
            gap: 0.5rem;
        }
    }
</style>
